{
  "name": "abp-filter-linter",
  "displayName": "ABP Filter Linter",
  "description": "Validates Adblock Plus filter syntax in .txt files",
  "version": "0.2.0",
  "publisher": "manuel-martinez-dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters"],
  "activationEvents": [
    "onLanguage:plaintext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "plaintext",
        "extensions": [".txt"]
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "test": "vitest run",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "css-what": "^6.1.0"
  }
}
