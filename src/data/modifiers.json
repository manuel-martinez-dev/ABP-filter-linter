{
  "valid": [
    "script", "image", "stylesheet", "subdocument",
    "xmlhttprequest", "websocket", "popup", "font", "media",
    "match-case", "document", "elemhide", "generichide",
    "genericblock", "third-party", "csp", "domain", "rewrite",
    "header", "addheader"
  ],
  "valueRequired": ["csp", "domain", "rewrite"],
  "rewritePrefix": "abp-resource:",
