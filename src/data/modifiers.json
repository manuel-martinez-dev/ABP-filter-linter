    "script", "image", "stylesheet", "subdocument",
    "xmlhttprequest", "websocket", "popup", "font", "media"
  ],
  "incompatible": {
    "document": ["script", "image", "stylesheet", "subdocument",
                 "xmlhttprequest", "websocket", "popup", "font", "media"]
  }
}
